{
  "name": "pi-fallback-provider",
  "version": "1.0.0",
  "description": "Model fallback chain extension for pi — automatic retry and failover across AI providers",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "pi-extension",
    "pi-package",
    "pi",
    "model-routing",
    "high-availability",
    "failover",
    "retry",
    "exponential-backoff"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xilnick/pi-fallback-router"
  },
  "bugs": {
    "url": "https://github.com/xilnick/pi-fallback-router/issues"
  },
  "homepage": "https://github.com/xilnick/pi-fallback-router#readme",
  "pi": {
    "extensions": ["./dist"]
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.66.1",
    "@types/node": "^25.6.0",
    "typescript": "^5.5.3",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "^0.66.0"
  }
}
